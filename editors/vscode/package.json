{
  "name": "confy-vscode",
  "displayName": "confy",
  "description": "Structural tree editor for TOML / JSON / JSONC / YAML config files",
  "version": "0.3.0",
  "publisher": "superyngo",
  "private": true,
  "license": "MIT",
  "icon": "icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "confy.editor",
        "displayName": "confy",
        "priority": "option",
        "selector": [
          { "filenamePattern": "*.toml" },
          { "filenamePattern": "*.json" },
          { "filenamePattern": "*.jsonc" },
          { "filenamePattern": "*.yaml" },
          { "filenamePattern": "*.yml" }
        ]
      }
    ],
    "commands": [
      { "command": "confy.openTextBeside", "title": "confy: Open Text Editor to the Side", "icon": "$(split-horizontal)" },
      { "command": "confy.openWithConfy", "title": "Open with confy", "icon": "$(list-tree)" },
      { "command": "confy.reopenAsText", "title": "confy: Reopen as Text Editor", "icon": "$(go-to-file)" },
      { "command": "confy.saveAsConvert", "title": "confy: Save As / Convert…" },
      { "command": "confy.help", "title": "confy: Help" },
      { "command": "confy.about", "title": "confy: About" },
      { "command": "confy.langEnglish", "title": "English" },
      { "command": "confy.langZhTw", "title": "繁體中文" }
    ],
    "submenus": [
      { "id": "confy.language", "label": "confy: Language / 語言" }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "confy.openWithConfy",
          "group": "navigation",
          "when": "resourceExtname =~ /^\\.(toml|jsonc?|ya?ml)$/ && activeCustomEditorId != 'confy.editor'"
        },
        {
          "command": "confy.reopenAsText",
          "group": "navigation@1",
          "when": "activeCustomEditorId == 'confy.editor'"
        },
        {
          "command": "confy.openTextBeside",
          "group": "navigation@2",
          "when": "activeCustomEditorId == 'confy.editor'"
        },
        {
          "command": "confy.saveAsConvert",
          "group": "1_confy@1",
          "when": "activeCustomEditorId == 'confy.editor'"
        },
        {
          "command": "confy.help",
          "group": "1_confy@2",
          "when": "activeCustomEditorId == 'confy.editor'"
        },
        {
          "command": "confy.about",
          "group": "1_confy@3",
          "when": "activeCustomEditorId == 'confy.editor'"
        },
        {
          "submenu": "confy.language",
          "group": "1_confy@4",
          "when": "activeCustomEditorId == 'confy.editor'"
        }
      ],
      "confy.language": [
        { "command": "confy.langEnglish", "group": "1_lang@1" },
        { "command": "confy.langZhTw", "group": "1_lang@2" }
      ],
      "commandPalette": [
        { "command": "confy.langEnglish", "when": "false" },
        { "command": "confy.langZhTw", "when": "false" }
      ]
    },
    "keybindings": [
      {
        "command": "confy.saveAsConvert",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "activeCustomEditorId == 'confy.editor'"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "tsc --noEmit",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
