{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true
  },
  "include": ["*.ts", "touch/*.ts", "../crates/confy-ffi/pkg/*.d.ts", "../i18n/*.json"]
}
