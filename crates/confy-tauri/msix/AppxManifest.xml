<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest for the confy desktop app (Microsoft Store submission).

  Placeholders substituted by pack-msix.ps1 at build time:
    __VERSION__          four-part x.y.z.0 derived from the release tag
    __IDENTITY_NAME__    Partner Center → Product identity → Package/Identity/Name
    __PUBLISHER__        Partner Center → Package/Identity/Publisher (CN=GUID)
    __PUBLISHER_DISPLAY__ Partner Center publisher display name

  Until the Store identity is reserved, the script defaults keep MakeAppx happy
  for CI/sideload builds; see msix/STORE.md for the submission flow.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="__IDENTITY_NAME__"
    Publisher="__PUBLISHER__"
    Version="__VERSION__"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>confy</DisplayName>
    <PublisherDisplayName>__PUBLISHER_DISPLAY__</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <!-- WebView2 is required at runtime but has no MSIX framework-package
         dependency; Win11 ships it inbox and Win10 gets it via Edge updates. -->
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="confy" Executable="confy-desktop.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="confy"
        Description="Structural editor for TOML / JSON / JSONC / YAML config files"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>
        <!-- "Open with confy" for the formats confy edits; startup_file() already
             handles a path argv, which MSIX activation passes through. -->
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="config">
            <uap:SupportedFileTypes>
              <uap:FileType>.toml</uap:FileType>
              <uap:FileType>.json</uap:FileType>
              <uap:FileType>.jsonc</uap:FileType>
              <uap:FileType>.yaml</uap:FileType>
              <uap:FileType>.yml</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
